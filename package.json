{
  "name": "daprova",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "api",
    "admin-web",
    "assessment-web",
    "shared"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=api",
    "dev:admin": "npm run dev --workspace=admin-web",
    "dev:assess": "npm run dev --workspace=assessment-web",
    "migrate": "npm run migrate --workspace=api",
    "seed": "npm run seed --workspace=api",
    "emulators": "firebase emulators:start --only auth"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "protobufjs@7.6.4": true
  }
}
